# FinTrack Environment Variables

# Google OAuth Client IDs
# PENTING: expo-auth-session membutuhkan "Web Application" Client ID di semua platform (Android, iOS, Web).
# Buat di: console.cloud.google.com → APIs & Services → Credentials → Create OAuth 2.0 Client ID → Web Application
# Tambahkan Authorized Redirect URI: https://auth.expo.io/@aavelazy/fintrack
#
# Android Client ID (SHA-1 fingerprint based) TIDAK bisa dipakai langsung dengan expo-auth-session.
# Isi EXPO_PUBLIC_GOOGLE_CLIENT_ID_ANDROID dengan Web Application Client ID yang sama.
EXPO_PUBLIC_GOOGLE_CLIENT_ID_WEB=placeholder-api-key.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_CLIENT_ID_ANDROID=placeholder-api-key.apps.googleusercontent.com

# Claude API Key (for LLM transaction parsing)
EXPO_PUBLIC_SUMOPOD_AI_API_KEY=placeholder-api-key

# Groq API Key (for Whisper Speech-to-Text)
EXPO_PUBLIC_GROQ_API_KEY=placeholder-api-key

