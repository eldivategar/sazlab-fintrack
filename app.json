{
  "expo": {
    "name": "SiPaling Hemat",
    "slug": "sipaling-hemat",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/sipaling-hemat-logo.png",
    "scheme": "sipaling-hemat",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/sipaling-hemat-logo.png",
      "bundleIdentifier": "com.sazlab.fintrack"
    },
    "android": {
      "package": "com.sazlab.fintrack",
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/sipaling-hemat-logo.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/sipaling-hemat-logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "image": "./assets/images/sipaling-hemat-logo.png",
          "imageWidth": 200
        }
      ],
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/sipaling-hemat-logo.png",
          "color": "#208AEF"
        }
      ],
      "@react-native-google-signin/google-signin",
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "98d7d2cd-d4bf-4329-8838-9971a9285462"
      }
    },
    "owner": "aavelazy"
  }
}
